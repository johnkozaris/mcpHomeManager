# MCP Home Manager — all settings optional. Just run: docker compose up -d

# --- Database ---
# Bring your own PostgreSQL (overrides the built-in container):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
# Or change the built-in container's password:
# POSTGRES_PASSWORD=change-me-in-production

# --- Encryption ---
# Auto-generated on first run. Back up for disaster recovery.
# ENCRYPTION_KEY=

# --- Application ---
# PUBLIC_URL=http://localhost:8000
# MCP_SERVER_NAME=My Homelab
# APP_PORT=8000
# DEBUG=false

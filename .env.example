# Copy this file to .env before running docker compose.
# For stable self-hosted installs, prefer the docker-compose.yml and .env.example
# attached to a GitHub Release instead of files from the main branch.

APP_PORT=8000
PUBLIC_URL=http://localhost:8000

# Web UI branding shown in the browser title, login/setup screens, and sidebar.
APP_NAME=MCP Manager

# MCP server name shown to MCP clients when they connect to your endpoint.
MCP_SERVER_NAME=My Homelab

# App image policy:
# - repo-root .env.example tracks the latest stable GHCR image
# - GitHub Release assets pin this value to the exact released version
MCP_HOME_IMAGE=ghcr.io/johnkozaris/mcp-home-manager:latest

# Supporting service images/config
POSTGRES_IMAGE=postgres:17-alpine
POSTGRES_DB=mcp_home
POSTGRES_USER=mcp
POSTGRES_PASSWORD=change-this-strong-password

# Optional: set DATABASE_URL if you need a fully custom connection string.
# The bundled compose stack still configures the included PostgreSQL service via
# POSTGRES_*, so treat this file as a starting point if you want an external DB.
# DATABASE_URL=postgresql+asyncpg://mcp:change-this-strong-password@db:5432/mcp_home

# Optional — customise your MCP Home Manager deployment.
# Copy to .env and uncomment/change only what you need.
# The compose file works without any .env file.

# --- App ---
# APP_PORT=8000
# APP_NAME=MCP Manager
# MCP_SERVER_NAME=My Homelab
# PUBLIC_URL=http://localhost:8000

# --- Database ---
# Default: SQLite (zero config, stored in app_data volume)
# For PostgreSQL: set DATABASE_URL or use docker-compose.postgres.yml
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# --- Advanced ---
# Encryption key for stored secrets. Auto-generated and persisted on first run.
# Only set this if you want to provide your own Fernet key (base64, 44 chars).
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# Docker Secrets / file-based secret injection (Swarm, Kubernetes, etc.):
# ENCRYPTION_KEY_FILE=/run/secrets/mcp_encryption_key
# DATABASE_URL_FILE=/run/secrets/mcp_database_url

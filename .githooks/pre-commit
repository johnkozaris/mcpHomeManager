#!/usr/bin/env bash
set -euo pipefail

# Get staged files per directory
FRONTEND_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- 'frontend/src/**' | sed 's|^frontend/||')
BACKEND_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- 'backend/src/**' | head -1)

if [ -n "$FRONTEND_FILES" ]; then
  cd frontend

  # Auto-fix: prettier + eslint on staged files, then re-stage
  echo "$FRONTEND_FILES" | xargs pnpm exec prettier --write --ignore-unknown
  echo "$FRONTEND_FILES" | xargs pnpm exec eslint --fix --no-error-on-unmatched-pattern || true
  echo "$FRONTEND_FILES" | sed 's|^|frontend/|' | (cd .. && xargs git add)

  # Check: these must pass (no auto-fix available)
  echo "▸ Frontend: oxlint"
  pnpm exec oxlint src/

  echo "▸ Frontend: eslint"
  pnpm exec eslint .

  echo "▸ Frontend: tsc"
  pnpm exec tsc -b

  cd ..
fi

if [ -n "$BACKEND_FILES" ]; then
  cd backend

  # Auto-fix: ruff format + fix, then re-stage
  uv run ruff format src/
  uv run ruff check --fix src/ || true
  cd ..
  git diff --name-only -- backend/src/ | xargs --no-run-if-empty git add
  cd backend

  # Check: these must pass
  echo "▸ Backend: ruff check"
  uv run ruff check src/

  echo "▸ Backend: ruff format --check"
  uv run ruff format --check src/

  echo "▸ Backend: mypy"
  uv run mypy

  echo "▸ Backend: semgrep"
  if command -v semgrep &>/dev/null; then
    semgrep scan --config "p/python" --config "p/owasp-top-ten" --config "p/security-audit" src/ --quiet --error
  else
    echo "  (semgrep not installed, skipping)"
  fi

  cd ..
fi

echo "✓ Pre-commit checks passed"

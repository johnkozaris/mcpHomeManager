{
  "name": "mcp-home-frontend",
  "private": true,
  "version": "0.1.0",
  "description": "React frontend for MCP Home Manager, a self-hosted MCP gateway for homelab services.",
  "license": "MIT",
  "type": "module",
  "author": "MCP Home Manager Contributors",
  "homepage": "https://github.com/johnkozaris/mcpHomeManager#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnkozaris/mcpHomeManager.git"
  },
  "bugs": {
    "url": "https://github.com/johnkozaris/mcpHomeManager/issues"
  },
  "keywords": [
    "mcp",
    "homelab",
    "react",
    "dashboard",
    "llm",
    "ai-agents"
  ],
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=24.13.1"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "oxlint src/ && eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "knip": {
    "entry": [
      "playwright.config.ts",
      "tests/e2e/**/*.test.ts"
    ]
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.166.7",
    "i18next": "^25.8.17",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-icu": "^2.4.3",
    "i18next-resources-to-backend": "^1.2.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.6",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.0.3",
    "eslint-plugin-oxlint": "^1.51.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^28.1.0",
    "knip": "^5.86.0",
    "oxlint": "^1.49.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "dompurify@<3.3.2": "^3.3.2"
    }
  }
}
